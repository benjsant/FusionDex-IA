POSTGRES_DB=fusiondex_db
POSTGRES_USER=fusiondex_user
POSTGRES_PASSWORD=changeme

# ─── Host ports (préfixe 5 pour éviter les collisions avec les défauts) ───
FUSIONDEX_FRONTEND_PORT=53000
FUSIONDEX_BACKEND_PORT=58000
FUSIONDEX_SPRITES_PORT=58080
FUSIONDEX_DB_PORT=55432
# Doc MkDocs (profil optionnel `--profile docs`)
FUSIONDEX_DOCS_PORT=58100
# Ollama LLM local (profil optionnel `--profile ollama`)
FUSIONDEX_OLLAMA_PORT=58200

# ─── CORS (defense in depth — le proxy Next masque déjà le backend en prod) ───
CORS_ALLOWED_ORIGINS=http://localhost:53000,http://localhost:58000

# ─── AI (optionnel — au moins un provider, sinon POST /ai/ask renvoie 503) ───
#
# Option 1 — DeepSeek (cloud, qualité maximale)
#   Obtenir une clé : https://platform.deepseek.com/
# DEEPSEEK_API_KEY=sk-...
#
# Option 2 — Ollama (local, autonome, sans clé)
#   1. docker compose --profile ollama up -d ollama
#   2. décommenter la ligne ci-dessous
#   3. docker compose restart backend
# OLLAMA_URL=http://ollama:11434
#
# Modèle Ollama (défaut: qwen2.5:3b ~2 GB, RAM 4 GB).
# Upgrades possibles : qwen2.5:7b (4.5 GB) si tu as un GPU 8 GB / Apple Silicon.
# OLLAMA_MODEL=qwen2.5:3b
