POSTGRES_DB=fusiondex_db
POSTGRES_USER=fusiondex_user
POSTGRES_PASSWORD=changeme

# ─── Host ports (préfixe 5 pour éviter les collisions avec les défauts) ───
FUSIONDEX_FRONTEND_PORT=53000
FUSIONDEX_BACKEND_PORT=58000
FUSIONDEX_SPRITES_PORT=58080
FUSIONDEX_DB_PORT=55432
# Doc MkDocs (profil optionnel `--profile docs`)
FUSIONDEX_DOCS_PORT=58100

# ─── CORS (defense in depth — le proxy Next masque déjà le backend en prod) ───
CORS_ALLOWED_ORIGINS=http://localhost:53000,http://localhost:58000

# ─── AI (optionnel) ───
# DEEPSEEK_API_KEY=
