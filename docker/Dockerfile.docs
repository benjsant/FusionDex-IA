# ── builder stage ────────────────────────────────────────────────────────────
FROM python:3.12-slim AS builder

COPY --from=ghcr.io/astral-sh/uv:0.10 /uv /uvx /bin/

ENV UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy

WORKDIR /app

# Installe uniquement le dep-group "docs" (mkdocs-material + plugins).
# Pas de source à installer — la doc est montée en volume au runtime.
COPY pyproject.toml uv.lock ./
RUN uv sync --frozen --only-group docs --no-install-project

# ── runtime stage ────────────────────────────────────────────────────────────
FROM python:3.12-slim AS runtime

WORKDIR /app

COPY --from=builder /app/.venv /app/.venv

ENV PATH="/app/.venv/bin:$PATH"

# docs/, mkdocs.yml, pyproject.toml, uv.lock sont montés en volume
# via docker-compose.yml → hot-reload à l'édition.
EXPOSE 58100

CMD ["mkdocs", "serve", "--dev-addr", "0.0.0.0:58100"]
