# ── builder stage ────────────────────────────────────────────────────────────
FROM python:3.12-slim AS builder

COPY --from=ghcr.io/astral-sh/uv:0.10 /uv /uvx /bin/

ENV UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy

WORKDIR /app

# Resolve deps from uv.lock. Cached as long as pyproject + uv.lock are unchanged.
COPY etl/pyproject.toml etl/uv.lock ./
RUN uv sync --frozen --no-dev --no-install-project

# Install the project itself on top of the cached dep layer.
COPY etl/ ./etl/
RUN uv sync --frozen --no-dev

# ── runtime stage ────────────────────────────────────────────────────────────
FROM python:3.12-slim AS runtime

WORKDIR /app

# Copy only the resolved venv and the source we need at runtime.
# uv, build caches, and the lockfile stay in the builder stage.
COPY --from=builder /app/.venv /app/.venv
COPY --from=builder /app/etl /app/etl
COPY docker/wait_for_db.py ./docker/wait_for_db.py

# Note: /app/data is provided at runtime via bind-mount (see docker-compose.yml).

ENV PATH="/app/.venv/bin:$PATH"

CMD ["sh", "-c", "python docker/wait_for_db.py && python etl/pipeline.py"]
